# ================================
# Servidor
# ================================
PORT=3000
NODE_ENV=development

# ================================
# Base de datos PostgreSQL
# ================================
DB_HOST=192.168.1.51
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
# [SECURE-FIX V6] DB_SSL controla la conexión TLS a PostgreSQL.
# En LAN/dev se deja vacío o false; en producción contra DB
# gestionada (RDS, Cloud SQL, Supabase) debe ser true.
DB_SSL=false

# ================================
# JWT
# ================================
# OWASP A02:2025 — usa secretos largos y aleatorios (min 32 bytes)
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=GENERAR_CON_node_-e_crypto.randomBytes(48).toString(base64)
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=GENERAR_CON_node_-e_crypto.randomBytes(48).toString(base64)
JWT_REFRESH_EXPIRATION=7d
# [SECURE-FIX V3] issuer + audience validados en cada verify — evita
# que un token emitido por otro servicio con el mismo secreto cuele aquí
JWT_ISSUER=clinic-api
JWT_AUDIENCE=clinic-web

# ================================
# Valkey (Redis-compatible) — blocklist de access tokens en logout
# OWASP A07:2021 — revocación inmediata; fail-open si no está disponible
# ================================
VALKEY_HOST=192.168.1.51
VALKEY_PORT=6379
VALKEY_PASSWORD=TU_PASSWORD_VALKEY

# ================================
# CORS — orígenes permitidos separados por coma
# OWASP A01:2021 — Broken Access Control
# ================================
ALLOWED_ORIGINS=http://localhost:4200

# ================================
# Swagger Basic Auth (solo en desarrollo)
# OWASP A05:2021 — Security Misconfiguration
# ================================
SWAGGER_USER=admin
SWAGGER_PASSWORD=SuperSecretSwagger#2025
